  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "module": "nodenext",
    "moduleResolution": "node16",
    "jsx": "react-jsx",
    "rootDir": "./",
    "outDir": "dist",
    "target": "esnext"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "index.d.ts"]
}
